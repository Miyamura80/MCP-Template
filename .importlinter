[importlinter]
root_packages =
    common
    utils
    src
    tests
    init
    commands
    services
    models
    mcp_server

[importlinter:contract:common_no_upper_layers]
name = Common does not import higher layers
type = forbidden
source_modules =
    common
forbidden_modules =
    utils
    src
    tests
    init

[importlinter:contract:utils_no_tests_init]
name = Utils does not import tests or init
type = forbidden
source_modules =
    utils
forbidden_modules =
    tests
    init

[importlinter:contract:src_no_tests_init]
name = Src does not import tests or init
type = forbidden
source_modules =
    src
forbidden_modules =
    tests
    init

[importlinter:contract:commands_allowed_imports]
name = Commands do not import tests or init
type = forbidden
source_modules =
    commands
forbidden_modules =
    tests
    init

[importlinter:contract:services_no_transport]
name = Services do not import CLI or MCP transport layers
type = forbidden
source_modules =
    services
forbidden_modules =
    tests
    init
    commands
    mcp_server

[importlinter:contract:models_are_pure]
name = Models do not import app layers
type = forbidden
source_modules =
    models
forbidden_modules =
    tests
    init
    commands
    services
    mcp_server
    src
    utils

[importlinter:contract:no_imports_from_tests]
name = Tests are not imported by app code
type = forbidden
source_modules =
    common
    utils
    src
    init
    commands
    services
    models
    mcp_server
forbidden_modules =
    tests

[importlinter:contract:init_is_leaf]
name = Init is a leaf module
type = forbidden
source_modules =
    common
    utils
    src
    tests
forbidden_modules =
    init
